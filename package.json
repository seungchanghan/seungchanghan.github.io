{
  "homepage": "https://seungchanghan.github.io/",
  "name": "seungchanghan-portfolio",
  "version": "1.0.0",
  "license": "GPL-3.0-only",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "test": "vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{html,js,jsx,css}\" \"package.json\"",
    "check-format": "prettier --check \"src/**/*.{html,js,jsx,css}\" \"package.json\"",
    "sync-pages": "npm run build && rm -rf assets && cp -a dist/. .",
    "qa": "npm run format && npm run test && npm run sync-pages",
    "preview:local": "vite preview --host 127.0.0.1 --port 4173",
    "playwright:install": "playwright install chromium",
    "playwright:shots": "playwright test",
    "qa:visual": "start-server-and-test preview:local http://127.0.0.1:4173 playwright:shots"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@vitejs/plugin-react": "6.0.2",
    "prettier": "3.8.4",
    "start-server-and-test": "^3.0.11",
    "vite": "8.0.16"
  }
}
